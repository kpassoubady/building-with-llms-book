flowchart LR
    subgraph System["🎭 System Message"]
        direction TB
        S1["Sets persona & role"]
        S2["Defines constraints"]
        S3["Establishes output format"]
        S4["Persists across turns"]
    end

    subgraph User["👤 User Message"]
        direction TB
