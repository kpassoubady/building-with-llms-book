        U4["Changes each turn"]
    end

    System --> R["🤖 Model<br/>Response"]
    User --> R

    style System fill:#e3f2fd,stroke:#1a73e8
    style User fill:#fff3e0,stroke:#e65100
    style R fill:#e8f5e9,stroke:#2e7d32
